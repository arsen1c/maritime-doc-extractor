NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/maritime-doc-extractor
REDIS_URL=redis://127.0.0.1:6379
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=
WORKER_CONCURRENCY=5
MAX_FILE_SIZE_BYTES=10485760
SYNC_MAX_FILE_SIZE_BYTES=4194304
SYNC_MAX_PDF_PAGES=5
LLM_TIMEOUT_MS=30000
REDIS_RATE_LIMIT_WINDOW_MS=60000
REDIS_RATE_LIMIT_MAX_REQUESTS=10
